[sub_resource type="Shader" id="Shader_star_field"]
code = "shader_type spatial;\nrender_mode unshaded, cull_front, depth_draw_never, blend_add, fog_disabled;\n\nuniform float star_visibility : hint_range(0.0, 1.0) = 0.0;\nuniform vec3 star_color : source_color = vec3(0.9, 0.95, 1.0);\nuniform float star_brightness : hint_range(0.0, 8.0) = 3.8;\nuniform float star_density = 950.0;\nuniform float star_threshold = 0.9975;\n\nfloat hash(vec2 p) {\n\treturn fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);\n}\n\nvoid fragment() {\n\tvec2 grid = UV * star_density;\n\tvec2 cell = floor(grid);\n\tfloat h = hash(cell);\n\tfloat star = step(star_threshold, h);\n\tfloat twinkle = 0.72 + 0.28 * sin(TIME * (1.8 + h * 4.0) + h * 42.0);\n\tfloat intensity = star * twinkle * star_visibility * star_brightness;\n\tALBEDO = vec3(0.0);\n\tEMISSION = star_color * intensity;\n\tALPHA = clamp(intensity, 0.0, 1.0);\n}\n"

